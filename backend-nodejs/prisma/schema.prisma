generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model category {
  id          Int        @id @default(autoincrement())
  name        String     @db.VarChar
  description String?    @db.VarChar
  created_at  DateTime   @db.Timestamp(6)
  updated_at  DateTime   @db.Timestamp(6)
  tenant_id   Int
  tenant      tenant     @relation(fields: [tenant_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  medicine    medicine[]
  product     product[]

  @@index([name], map: "ix_category_name")
  @@index([tenant_id], map: "ix_category_tenant_id")
}

model medicine {
  id             Int            @id @default(autoincrement())
  name           String         @db.VarChar
  description    String?        @db.VarChar
  unit           String         @db.VarChar(50)
  quantity       Int
  purchase_price Decimal        @db.Decimal
  selling_price  Decimal        @db.Decimal
  is_active      Boolean
  created_at     DateTime       @db.Timestamp(6)
  updated_at     DateTime       @db.Timestamp(6)
  category_id    Int?
  tenant_id      Int
  category       category?      @relation(fields: [category_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  tenant         tenant         @relation(fields: [tenant_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  productbatch   productbatch[]
  saleitem       saleitem[]

  @@index([category_id], map: "ix_medicine_category_id")
  @@index([name], map: "ix_medicine_name")
  @@index([tenant_id], map: "ix_medicine_tenant_id")
}

model product {
  id             Int      @id @default(autoincrement())
  generic_name   String   @db.VarChar
  name           String   @db.VarChar
  description    String?  @db.VarChar
  unit           String   @db.VarChar(50)
  quantity       Int
  purchase_price Decimal  @db.Decimal
  selling_price  Decimal  @db.Decimal
  tax_percentage Decimal  @db.Decimal
  is_active      Boolean
  created_at     DateTime @db.Timestamp(6)
  updated_at     DateTime @db.Timestamp(6)
  category_id    Int
  tenant_id      Int
  category       category @relation(fields: [category_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  tenant         tenant   @relation(fields: [tenant_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([category_id], map: "ix_product_category_id")
  @@index([name], map: "ix_product_name")
  @@index([tenant_id], map: "ix_product_tenant_id")
}

model productbatch {
  id             Int      @id @default(autoincrement())
  medicine_id    Int
  batch_number   String   @db.VarChar
  quantity       Int
  expiry_date    DateTime @db.Timestamp(6)
  purchase_price Decimal  @db.Decimal
  created_at     DateTime @db.Timestamp(6)
  updated_at     DateTime @db.Timestamp(6)
  medicine       medicine @relation(fields: [medicine_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([batch_number], map: "ix_productbatch_batch_number")
  @@index([medicine_id], map: "ix_productbatch_medicine_id")
}

model sale {
  id             Int        @id @default(autoincrement())
  total_amount   Decimal    @db.Decimal
  discount       Decimal    @db.Decimal
  final_amount   Decimal    @db.Decimal
  payment_method String     @db.VarChar
  created_at     DateTime   @db.Timestamp(6)
  tenant_id      Int
  user_id        String     @db.Uuid
  tenant         tenant     @relation(fields: [tenant_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  user           user       @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  saleitem       saleitem[]

  @@index([tenant_id], map: "ix_sale_tenant_id")
}

model saleitem {
  id          Int      @id @default(autoincrement())
  sale_id     Int
  medicine_id Int
  quantity    Int
  unit_price  Decimal  @db.Decimal
  total_price Decimal  @db.Decimal
  medicine    medicine @relation(fields: [medicine_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  sale        sale     @relation(fields: [sale_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

model supplier {
  id             String   @id @db.Uuid
  company_name   String   @db.VarChar
  contact_person String   @db.VarChar
  email          String   @unique(map: "ix_supplier_email") @db.VarChar
  phone          String   @unique(map: "ix_supplier_phone") @db.VarChar
  address        String   @db.VarChar
  created_at     DateTime @db.Timestamp(6)
  updated_at     DateTime @db.Timestamp(6)
  tenant_id      Int
  tenant         tenant   @relation(fields: [tenant_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([tenant_id], map: "ix_supplier_tenant_id")
}

model tenant {
  id         Int        @id @default(autoincrement())
  name       String     @db.VarChar
  address    String     @db.VarChar
  city       String     @db.VarChar
  phone      String     @unique @db.VarChar
  email      String     @unique @db.VarChar
  timezone   String     @db.VarChar
  currency   String     @db.VarChar
  is_active  Boolean
  created_at DateTime   @db.Timestamp(6)
  updated_at DateTime   @db.Timestamp(6)
  category   category[]
  medicine   medicine[]
  product    product[]
  sale       sale[]
  supplier   supplier[]
  user       user[]
}

model user {
  id              String   @id @db.Uuid
  full_name       String   @db.VarChar
  username        String   @unique @db.VarChar
  hashed_password String   @db.VarChar
  created_at      DateTime @db.Timestamp(6)
  updated_at      DateTime @db.Timestamp(6)
  role            userrole
  is_active       Boolean
  tenant_id       Int?
  sale            sale[]
  tenant          tenant?  @relation(fields: [tenant_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

enum userrole {
  ADMIN
  STAFF
}
